# Auto detect text files and perform LF normalization
* text=auto

# Force LF for shell scripts (critical for Docker containers)
*.sh text eol=lf

# Force LF for generated/doc files to avoid mixed-line-ending churn on Windows
*.rst text eol=lf
*.md text eol=lf
*.csv text eol=lf
*.xml text eol=lf
*.py text eol=lf
